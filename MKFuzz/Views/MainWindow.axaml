<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MKFuzz.ViewModels"
        x:Class="MKFuzz.Views.MainWindow"
        Title="Fuzzing Orchestrator"
        Width="1000" Height="700">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*"  x:DataType="vm:MainWindowViewModel">
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="_Open Project" Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}"/>
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
        </Menu>

	    <TabControl Grid.Row="1">
		    <TabItem Header="Project Setup" IsEnabled="True">
			    <ContentControl Content="{Binding Tabs[0]}" />
		    </TabItem>
		    <TabItem Header="Fuzzing" IsEnabled="{Binding IsFuzzingContainerRunning}">
			    <ContentControl Content="{Binding Tabs[1]}" />
		    </TabItem>
		    <TabItem Header="Results" IsEnabled="{Binding IsFuzzingContainerRunning}">
			    <ContentControl Content="{Binding Tabs[2]}" />
		    </TabItem>
        </TabControl>
    </Grid>
</Window>