<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKFuzz.ViewModels"
             x:Class="MKFuzz.Views.FuzzingView"
             x:DataType="vm:FuzzingViewModel">
    <Design.DataContext>
        <vm:FuzzingViewModel />
    </Design.DataContext>
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="5">
            <Button Content="Build Fuzz Target" Command="{Binding BuildFuzzCommand}"/>
            <Button Content="Build Coverage Target" Command="{Binding BuildCoverageCommand}"/>
            <Button Content="Start Fuzzing" Command="{Binding StartFuzzingCommand}"/>
            <Button Content="Resume Fuzzing" Command="{Binding ResumeFuzzingCommand}"/>
            <Button Content="Stop Fuzzing" Command="{Binding StopFuzzingCommand}"/>
            <Button Content="Analyze Results" Command="{Binding AnalyzeCommand}"/>
        </StackPanel>

        <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,*" DockPanel.Dock="Bottom">
            <!-- Log area -->
            <Border Grid.Row="0"  Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,5">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <Border Grid.Column="1"  BorderBrush="Gray" BorderThickness="1" Margin="0,5">
                <ScrollViewer>
                    <TextBlock Text="{Binding RawStats}" FontFamily="Consolas" FontSize="11"
                    TextWrapping="Wrap" Background="#F8F8F8" Padding="5"/>
                </ScrollViewer>
            </Border>

            <!-- Status message -->
            <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="Blue" Margin="0,5"/>
        </Grid>
    </DockPanel>
</UserControl>