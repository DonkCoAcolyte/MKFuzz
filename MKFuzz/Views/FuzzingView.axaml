<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKFuzz.ViewModels"
             x:Class="MKFuzz.Views.FuzzingView"
             x:DataType="vm:FuzzingViewModel">
    <Design.DataContext>
        <vm:FuzzingViewModel />
    </Design.DataContext>
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="5">
            <Button Content="Build Fuzz Target" Command="{Binding BuildFuzzCommand}"/>
            <Button Content="Build Coverage Target" Command="{Binding BuildCoverageCommand}"/>
            <Button Content="Start Fuzzing" Command="{Binding StartFuzzingCommand}"/>
            <Button Content="Resume Fuzzing" Command="{Binding ResumeFuzzingCommand}"/>
            <Button Content="Stop Fuzzing" Command="{Binding StopFuzzingCommand}"/>
            <Button Content="Analyze Results" Command="{Binding AnalyzeCommand}"/>
        </StackPanel>

        <Grid RowDefinitions="Auto,*,Auto" DockPanel.Dock="Bottom">
            <!-- Stats -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Margin="0,5">
                <StackPanel Orientation="Horizontal" Spacing="20" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Fuzzers alive" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Stats.FuzzersAlive}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Total execs" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Stats.TotalExecs}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Execs/sec" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Stats.ExecsPerSecond}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Crashes" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Stats.Crashes}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Coverage" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Stats.Coverage, StringFormat={}{0:F2}%}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Pending items" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Stats.PendingItems}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Log area -->
            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="0,5">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Status message -->
            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="Blue" Margin="0,5"/>
        </Grid>
    </DockPanel>
</UserControl>