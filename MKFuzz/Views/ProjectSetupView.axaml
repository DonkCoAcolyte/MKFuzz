<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKFuzz.ViewModels"
             x:Class="MKFuzz.Views.ProjectSetupView"
             x:DataType="vm:ProjectSetupViewModel">
    <Design.DataContext>
        <vm:ProjectSetupViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="10" Spacing="10">
            <TextBox Watermark="Project Name" Text="{Binding Project.Name}"/>

            <!-- Source Folder -->
            <WrapPanel>
                <TextBlock VerticalAlignment="Center" Width="120">Source Folder:</TextBlock>
                <TextBox Text="{Binding Project.SourcePath}" Width="300"/>
                <Button Content="Browse" Command="{Binding BrowseSourceCommand}" Margin="5,0"/>
                <TextBlock Text="{Binding SourceFolder, StringFormat='copied to: {0}'}" 
                       VerticalAlignment="Center" Foreground="Gray"/>
            </WrapPanel>

	<!-- Harness File -->
	<WrapPanel>
		<TextBlock VerticalAlignment="Center" Width="120">Harness File:</TextBlock>
		<TextBox Text="{Binding Project.HarnessPath}" Width="300"/>
		<Button Content="Browse" Command="{Binding BrowseHarnessCommand}" Margin="5,0"/>
		<Button Content="Edit" Command="{Binding EditHarnessCommand}" Margin="5,0"/>
		<TextBlock VerticalAlignment="Center" Foreground="Gray">(Optional)</TextBlock>
    </WrapPanel>

            <!-- Seeds Folder -->
            <WrapPanel>
                <TextBlock VerticalAlignment="Center" Width="120">Seeds Folder:</TextBlock>
                <TextBox Text="{Binding Project.SeedsPath}" Width="300"/>
                <Button Content="Browse" Command="{Binding BrowseSeedsCommand}" Margin="5,0"/>
                <TextBlock Text="{Binding MountSeeds, StringFormat='Mounted at: {0}'}" 
                       VerticalAlignment="Center" Foreground="Gray"/>
            </WrapPanel>

            <!-- Output Folder -->
            <WrapPanel>
                <TextBlock VerticalAlignment="Center" Width="120">Output Folder:</TextBlock>
                <TextBox Text="{Binding Project.OutputPath}" Width="300"/>
                <Button Content="Browse" Command="{Binding BrowseOutputCommand}" Margin="5,0"/>
                <TextBlock Text="{Binding MountOutput, StringFormat='Mounted at: {0}'}" 
                       VerticalAlignment="Center" Foreground="Gray"/>
            </WrapPanel>

            <!-- Docker status panel -->
            <WrapPanel Margin="0,5">
                <TextBlock VerticalAlignment="Center" Text="Docker: " />
                <TextBlock VerticalAlignment="Center" Text="{Binding MainVm.DockerStatus}" Foreground="{Binding MainVm.DockerStatusColor}" Margin="5,0"/>
                <Button Content="Check Environment" Command="{Binding MainVm.CheckEnvironmentCommand}" Margin="5,0"/>
            </WrapPanel>

            <!-- Fuzzing Setup -->
            <Expander Header="Fuzzing Setup">
				<StackPanel Margin="10" Spacing="10">
                    <WrapPanel>
                        <TextBlock VerticalAlignment="Center" Width="250">Build system:</TextBlock>
                        <ComboBox ItemsSource="{Binding BuildSystems}" SelectedItem="{Binding Project.BuildSystem}" Width="200"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock VerticalAlignment="Center" Width="250">Input type:</TextBlock>
                        <ComboBox ItemsSource="{Binding InputTypes}" SelectedItem="{Binding Project.InputType}" Width="200"/>
                    </WrapPanel>
                    <CheckBox IsChecked="{Binding Project.UseSanitizers}">Use sanitizers</CheckBox>
                    <CheckBox IsChecked="{Binding Project.UseCMPLOG}">Use CMPLOG</CheckBox>
                    <CheckBox IsChecked="{Binding Project.GenerateCoverage}">Generate coverage report</CheckBox>
                </StackPanel>
            </Expander>

            <Expander Header="Build and Target">
                <StackPanel Margin="10" Spacing="10">
                    <!-- Fuzz build command from ViewModel -->
                    <StackPanel>
                        <TextBlock Text="Fuzz build command:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Project.FuzzBuildCommand}" Margin="5,0"/>
                        <TextBlock Text="Fuzz binary path (in container):" Margin="0,0,0,5"/>
                        <TextBox Watermark="Fuzz binary path (in container)" Text="{Binding Project.FuzzBinaryPath}"/>
                    </StackPanel>

                    <!-- Sanitizers build command from ViewModel -->
                    <StackPanel>
                        <TextBlock Text="Sanitizer build command:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Project.SanitizersBuildCommand}" Margin="5,0" IsEnabled="{Binding Project.UseSanitizers}"/>
                        <TextBlock Text="Sanitized binary path (in container):" Margin="0,0,0,5"/>
                        <TextBox Watermark="Sanitized binary path (in container)" Text="{Binding Project.SanitizersBinaryPath}" IsEnabled="{Binding Project.UseSanitizers}"/>
                    </StackPanel>

                    <!-- CMPLOG build command from ViewModel -->
                    <StackPanel>
                        <TextBlock Text="CMPLOG build command:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Project.CmplogBuildCommand}" Margin="5,0" IsEnabled="{Binding Project.UseCMPLOG}"/>
                        <TextBlock Text="CMPLOG binary path (in container):" Margin="0,0,0,5"/>
                        <TextBox Watermark="CMPLOG binary path (in container)" Text="{Binding Project.CmplogBinaryPath}" IsEnabled="{Binding Project.UseCMPLOG}"/>
                    </StackPanel>

                    <!-- Coverage build command -->
                    <StackPanel>
                        <TextBlock Text="Coverage build command:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <TextBox Text="{Binding Project.CoverageBuildCommand}" Margin="5,0" IsEnabled="{Binding Project.GenerateCoverage}" />
                        <TextBlock Text="Coverage binary path (in container):" Margin="0,0,0,5"/>
                        <TextBox Watermark="Coverage binary path (in container)" Text="{Binding Project.CovBinaryPath}" IsEnabled="{Binding Project.GenerateCoverage}"/>
                    </StackPanel>

                    <!-- Target arguments -->
                    <TextBlock Text="Target arguments:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Watermark="Target arguments (use @@ for input)" Text="{Binding Project.TargetArgs}"/>
                </StackPanel>
            </Expander>

            <Expander Header="Fuzzing Settings">
                <StackPanel Margin="10" Spacing="5">
                    <WrapPanel>
                        <TextBlock VerticalAlignment="Center" Width="250">CPU Cores:</TextBlock>
                        <NumericUpDown Value="{Binding Project.Cores}" Minimum="1" Maximum="64" Width="200"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock VerticalAlignment="Center" Width="250">Stop condition:</TextBlock>
                        <ComboBox ItemsSource="{Binding StopConditions}" SelectedItem="{Binding Project.StopWhy}" Width="200"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock VerticalAlignment="Center" Width="250">Crashes:</TextBlock>
                        <NumericUpDown Value="{Binding Project.StopValue}" Minimum="1" Width="200"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock VerticalAlignment="Center" Width="250">Stats-update interval (seconds):</TextBlock>
                        <NumericUpDown Value="{Binding Project.AflFuzzerStatsUpdateIntervalSeconds}" Minimum="1" Width="200"/>
                    </WrapPanel>
                    <CheckBox IsChecked="{Binding Project.KeepContainerAlive}">Keep container (alive)</CheckBox>
                    <CheckBox IsChecked="{Binding Project.SanitizeFilenames}">Sanitize filenames (crossrename)</CheckBox>
                </StackPanel>
            </Expander>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save Project" Command="{Binding MainVm.SaveProjectCommand}" Margin="5"/>
                <Button Content="Start Container" Command="{Binding StartContainerCommand}" Margin="5"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" Foreground="Blue"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>